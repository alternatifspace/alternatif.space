{
  "name": "alternatif-space",
  "private": true,
  "version": "0.1.0",
  "description": "alternatif.space — civic technology platform (partai, mufakat, simposium, perpus)",
  "scripts": {
		"dev": "pnpm --parallel --filter partai --filter mufakat --filter www dev",
		"dev:partai": "pnpm --filter partai dev",
		"dev:mufakat": "pnpm --filter mufakat dev",
		"dev:www": "pnpm --filter www dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "supabase": "^2.105.0"
  }
}
