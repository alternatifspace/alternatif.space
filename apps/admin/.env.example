# LOCAL-ONLY admin tool — point these at the PRODUCTION Supabase project.
# Copy to apps/admin/.env (auto-gitignored) and fill in real values.
#
# Get both from: Supabase Dashboard → Project Settings → API
#   - SUPABASE_URL            = "Project URL"
#   - SUPABASE_SERVICE_ROLE_KEY = "service_role" secret (NOT the anon key)
#
# The service_role key bypasses Row Level Security. Never commit it, never
# deploy this app, never paste this key anywhere outside this local .env.

SUPABASE_URL=https://your-prod-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key
