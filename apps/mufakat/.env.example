# Supabase (TRD §4)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk (TRD §4, §5)
# Production instance must run on alternatif.space so the session cookie is
# scoped to .alternatif.space (cross-subdomain SSO). The 'supabase' JWT
# template must map `sub` to the user's Supabase UUID.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
